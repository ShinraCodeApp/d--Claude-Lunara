# ─── Lunara Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Lunara

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://lunara:YOUR_PASSWORD@localhost:5432/lunara_dev
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379

# ─── JWT Secrets (generate with: openssl rand -base64 64) ─────
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ─── Firebase (Push Notifications) ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Apple Push Notifications ─────────────────────────────────
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_BUNDLE_ID=com.shinracode.lunara
APNS_PRIVATE_KEY_PATH=./certs/apns-auth-key.p8

# ─── RevenueCat ───────────────────────────────────────────────
REVENUECAT_API_KEY=sk_...
REVENUECAT_WEBHOOK_SECRET=whsec_...

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=lunara-assets-dev

# ─── AI Service ───────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=CHANGE_ME_INTERNAL_SERVICE_KEY

# ─── Admin Panel ──────────────────────────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT_SECRET

# ─── Sentry (Error Tracking) ──────────────────────────────────
SENTRY_DSN=https://...@o...ingest.sentry.io/...

# ─── Email (AWS SES) ──────────────────────────────────────────
SES_FROM_EMAIL=noreply@lunara.app
SES_REGION=us-east-1

# ─── Google AdMob ─────────────────────────────────────────────
ADMOB_APP_ID=ca-app-pub-...
ADMOB_BANNER_ID=ca-app-pub-...
ADMOB_REWARDED_ID=ca-app-pub-...

# ─── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_KEY_FOR_AES

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,https://admin.lunara.app
