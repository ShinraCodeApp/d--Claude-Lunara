    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "@sentry/react-native": "~5.22.2",
    "@shopify/flash-list": "1.6.4",
    "@tanstack/react-query": "^5.49.2",
    "axios": "^1.7.2",
    "dayjs": "^1.11.11",
    "expo": "~51.0.14",
    "expo-blur": "~13.0.2",
    "expo-constants": "^56.0.17",
    "expo-font": "~12.0.7",
