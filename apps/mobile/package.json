{
  "name": "@lunara/mobile",
  "version": "1.0.0",
  "description": "Lunara Mobile App — React Native + Expo",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
