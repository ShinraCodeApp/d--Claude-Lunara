{
  "expo": {
    "name": "Lunara",
    "slug": "lunara",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./assets/images/LunaraByShinraCode.png",
    "scheme": "lunara",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0118"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shinracode.lunara",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Lunara necesita acceso a Salud para sincronizar tus datos de ciclo.",
        "NSHealthUpdateUsageDescription": "Lunara registrará tus datos menstruales en Apple Health.",
        "NSUserTrackingUsageDescription": "Usamos datos de forma anónima para mejorar tu experiencia."
      },
      "config": {
        "googleSignIn": {
          "reservedClientId": "com.googleusercontent.apps.YOUR-CLIENT-ID"
        }
      },
      "associatedDomains": [
        "applinks:lunara.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LunaraByShinraCode.png",
        "backgroundColor": "#1a0533"
      },
      "package": "com.shinracode.lunara",
      "versionCode": 6,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#8b5cf6",
          "sounds": []
        }
      ],
      "./plugins/withAndroidWidget.js",
      "./plugins/withiOSWidget.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "389b5a11-7cec-4052-a48b-b2f7e37bbf9a"
      }
    },
    "owner": "shinracode"
  }
}
