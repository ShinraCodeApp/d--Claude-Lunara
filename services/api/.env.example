# Lunara API — Variables de entorno para Railway
# Copia este archivo como .env para desarrollo local (NUNCA subas .env a git)

# === REQUERIDAS (Railway las provee automáticamente con sus plugins) ===
DATABASE_URL=postgresql://user:password@host:5432/lunara_db
REDIS_URL=redis://default:password@host:6379

# === JWT — Genera con: .\scripts\generate-secrets.ps1 ===
JWT_ACCESS_SECRET=CAMBIA_ESTO_POR_64_CHARS_HEX_MIN_32
JWT_REFRESH_SECRET=CAMBIA_ESTO_POR_64_CHARS_HEX_MIN_32

# === OPCIONALES (el servidor arranca sin estas) ===
NODE_ENV=production
PORT=3000

# AI Service — Configura cuando tengas el microservicio Python deployado
# AI_SERVICE_URL=https://lunara-ai.railway.app
# AI_SERVICE_API_KEY=

# Notificaciones push
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Pagos (RevenueCat)
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=

# Storage (AWS S3 o R2)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=lunara-assets

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sentry (monitoring)
# SENTRY_DSN=

# CORS — Pon la URL de tu app web aquí
# FRONTEND_URL=https://lunara.app
# ALLOWED_ORIGINS=https://lunara.app
