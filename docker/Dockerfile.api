FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache openssl

# ─── Dependencies ─────────────────────────────────────────────
FROM base AS deps
COPY package.json yarn.lock ./
COPY services/api/package.json ./services/api/
RUN yarn install --frozen-lockfile

# ─── Development ──────────────────────────────────────────────
FROM base AS development
ENV NODE_ENV=development
COPY --from=deps /app/node_modules ./node_modules
COPY services/api ./
RUN npx prisma generate
EXPOSE 3000
CMD ["yarn", "dev"]

# ─── Builder ──────────────────────────────────────────────────
FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY services/api ./
RUN npx prisma generate
RUN yarn build

# ─── Production ───────────────────────────────────────────────
FROM base AS production
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 lunara
COPY --from=builder --chown=lunara:nodejs /app/dist ./dist
COPY --from=builder --chown=lunara:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=lunara:nodejs /app/prisma ./prisma
COPY --from=builder --chown=lunara:nodejs /app/package.json ./
USER lunara
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1
CMD ["node", "dist/server.js"]
